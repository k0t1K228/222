local Effects = require(script.Parent.Effects)

local BaseClass = {}
BaseClass.__index = BaseClass

function BaseClass.new(model)
	local self    = setmetatable({}, BaseClass)
	self.model    = model
	self.maxHP    = 10000
	self.hp       = 10000
	self.isAlive  = true
	self.rootPart = nil
	self:createHPBar() -- вот этого не было!
	return self
end

function BaseClass:createHPBar()
	local root = self.model:FindFirstChild("TowerBase")
		or self.model:FindFirstChildWhichIsA("BasePart")
	if not root then
		warn("GeneralTower: не найдена основная часть!")
		return
	end

	self.rootPart = root

	local billboard = Instance.new("BillboardGui")
	billboard.Size        = UDim2.new(8, 0, 1, 0)
	billboard.StudsOffset = Vector3.new(0, 15, 0)
	billboard.AlwaysOnTop = false
	billboard.Parent      = root

	local title = Instance.new("TextLabel")
	title.Size                   = UDim2.new(1, 0, 0.4, 0)
	title.Position               = UDim2.new(0, 0, -0.5, 0)
	title.BackgroundTransparency = 1
	title.TextColor3             = Color3.fromRGB(255, 220, 0)
	title.TextScaled             = true
	title.Font                   = Enum.Font.GothamBold
	title.Text                   = "⚡ ГЛАВНАЯ БАЗА"
	title.Parent                 = billboard

	local bg = Instance.new("Frame")
	bg.Size             = UDim2.new(1, 0, 0.5, 0)
	bg.Position         = UDim2.new(0, 0, 0.5, 0)
	bg.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
	bg.BorderSizePixel  = 0
	bg.Parent           = billboard

	local bar = Instance.new("Frame")
	bar.Name             = "HPBar"
	bar.Size             = UDim2.new(1, 0, 1, 0)
	bar.BackgroundColor3 = Color3.fromRGB(0, 180, 255)
	bar.BorderSizePixel  = 0
	bar.Parent           = bg
	Instance.new("UICorner", bar).CornerRadius = UDim.new(0, 4)

	local label = Instance.new("TextLabel")
	label.Size                   = UDim2.new(1, 0, 1, 0)
	label.BackgroundTransparency = 1
	label.TextColor3             = Color3.fromRGB(255, 255, 255)
	label.TextScaled             = true
	label.Font                   = Enum.Font.GothamBold
	label.Text                   = "10000 / 10000"
	label.Parent                 = bg

	self.hpBar   = bar
	self.hpLabel = label
end

function BaseClass:updateHPBar()
	if not self.hpBar then return end
	local pct = self.hp / self.maxHP
	self.hpBar.Size   = UDim2.new(pct, 0, 1, 0)
	self.hpLabel.Text = math.floor(self.hp) .. " / " .. self.maxHP
	if pct > 0.5 then
		self.hpBar.BackgroundColor3 = Color3.fromRGB(0, 180, 255)
	elseif pct > 0.25 then
		self.hpBar.BackgroundColor3 = Color3.fromRGB(255, 150, 0)
	else
		self.hpBar.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
	end
end

function BaseClass:takeDamage(amount)
	if not self.isAlive then return end
	self.hp = math.max(0, self.hp - amount)
	self:updateHPBar()

	-- красная цифра урона над базой
	if self.rootPart then
		Effects.damageNumber(self.rootPart.Position + Vector3.new(0, 10, 0), amount, Color3.fromRGB(255, 70, 70))
	end
	print("База HP: " .. self.hp .. "/" .. self.maxHP)

	local gameData = game:GetService("ReplicatedStorage"):FindFirstChild("GameData")
	if gameData then
		local hpVal = gameData:FindFirstChild("BaseHP")
		if hpVal then hpVal.Value = self.hp end
	end

	if self.hp <= 0 then self:destroy() end
end

function BaseClass:destroy()
	self.isAlive = false
	print("БАЗА УНИЧТОЖЕНА! GAME OVER!")
	if self.onDestroyed then self.onDestroyed() end
end

-- Рестарт игры: база снова целая
function BaseClass:reset()
	self.hp = self.maxHP
	self.isAlive = true
	self:updateHPBar()

	local gameData = game:GetService("ReplicatedStorage"):FindFirstChild("GameData")
	if gameData then
		local hpVal = gameData:FindFirstChild("BaseHP")
		if hpVal then hpVal.Value = self.hp end
	end
end

return BaseClass